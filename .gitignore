# Knowledge base file-backed prototype store (admin-uploaded reference
# material per NFR-4 — no applicant PII — but still gitignored so the
# repo doesn't carry per-machine indexed corpora).
.data/

# Offline eval harness output (P5-2). Reports are per-run artifacts —
# the runner writes timestamped JSON + Markdown under eval-reports/;
# keep the directory out of the repo so the working tree stays clean.
eval-reports/

# Agent-correction feedback corpus (P5-3). The JSONL files under
# eval-data/agent-corrections/ are captured ground-truth signal, not
# committed source — the file-backed store is the prototype; P6-2
# moves the corpus into the governed datastore.
eval-data/
